# AsyncFlow — local configuration. Copy to .env: cp .env.example .env
# Every value below is the default; override only what you need.

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT_PUBLIC=5432

# RabbitMQ (management UI at http://localhost:15672, user/pass below)
RABBITMQ_USER=user
RABBITMQ_PASS=pass

# Service ports
API_GATEWAY_PORT=9000
ORDER_SERVICE_PORT=9001
BILLING_SERVICE_PORT=9002
AUTH_SERVICE_PORT=9003

# Frontend
FRONTEND_PORT=3000

# pgAdmin (optional GUI)
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=admin
PGADMIN_PORT=5050
